{
  "name": "svelteboy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "pnpm run asbuild:debug && node tests",
    "test:web": "vitest run",
    "asbuild:debug": "asc assembly/index.debug.ts --target debug",
    "asbuild:debugrelease": "asc assembly/index.debug.ts --target debugrelease",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild:instrumented": "asc assembly/index.debug.ts --target debugrelease --use INSTRUMENTED=1",
    "asbuild:profilerelease": "asc assembly/index.ts --target profilerelease",
    "dev": "vite",
    "build": "pnpm run asbuild:release && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "start": "pnpm dlx serve dist",
    "bench": "node tools/runrom/index.js roms/boot/dmg_boot.bin \"roms/games/Pokemon - Yellow Version (UE) [C][!].gb\" --benchmark",
    "bench:build": "pnpm asbuild:release && pnpm run bench",
    "bench:browser": "node tools/bench-browser/index.js roms/boot/dmg_boot.bin \"roms/games/Pokemon - Yellow Version (UE) [C][!].gb\"",
    "bench:browser:build": "pnpm asbuild:release && pnpm run bench:browser",
    "bench:compare": "node tools/bench-browser/compare.js",
    "profile": "node tools/runrom/index.js roms/boot/dmg_boot.bin \"roms/games/Pokemon - Yellow Version (UE) [C][!].gb\" --profile",
    "profile:build": "pnpm asbuild:profilerelease && pnpm run profile",
    "profile:instrumented": "node tools/runrom/index.js roms/boot/dmg_boot.bin \"roms/games/Pokemon - Yellow Version (UE) [C][!].gb\" --profile --instrumented",
    "profile:build:instrumented": "pnpm asbuild:instrumented && pnpm run profile:instrumented",
    "profile:fn": "node tools/runrom/index.js roms/boot/dmg_boot.bin \"roms/games/Pokemon - Yellow Version (UE) [C][!].gb\" --profile-function",
    "profile:fn:build": "pnpm asbuild:profilerelease && node tools/runrom/index.js roms/boot/dmg_boot.bin \"roms/games/Pokemon - Yellow Version (UE) [C][!].gb\" --profile-function"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.6.0",
    "assemblyscript": "^0.28.13",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "playwright": "^1.59.1",
    "rollup": "^4.60.1",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.6",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@csstools/convert-colors": "^2.0.1",
    "fflate": "^0.8.2",
    "gzip": "^0.1.0",
    "pngjs": "^7.0.0"
  },
  "exports": {
    ".": {
      "import": "./build/release/backend.js",
      "types": "./build/release/backend.d.ts"
    }
  }
}
