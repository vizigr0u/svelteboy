{
  "name": "svelteboy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "npm run asbuild:debug && node tests",
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:debugrelease": "asc assembly/index.ts --target debugrelease",
    "asbuild:release": "asc assembly/index.ts --target release",
    "dev": "vite",
    "build": "npm run asbuild:release && vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "start": "npx serve dist"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^25.0.0",
    "assemblyscript": "^0.28.0",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "tslib": "^2.6.0",
    "typescript": "^5.1.6",
    "vite": "^8.0.0",
    "vite-plugin-node-polyfills": "^0.25.0",
    "vite-plugin-top-level-await": "^1.6.0"
  },
  "dependencies": {
    "@csstools/convert-colors": "^2.0.1",
    "buffer": "^6.0.3",
    "gzip": "^0.1.0",
    "pngjs": "^7.0.0",
    "svelte-virtual-list-ce": "^3.1.0-beta.2"
  },
  "exports": {
    ".": {
      "import": "./build/release/backend.js",
      "types": "./build/release/backend.d.ts"
    }
  }
}
